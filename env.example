# ── neoxr.eu QRIS Gateway ──────────────────────────────────────
NEOXR_API_KEY=your_neoxr_api_key_here
NEOXR_USERNAME=your_username_here

# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Used server-side (API routes)

# ── Admin Panel ─────────────────────────────────────────────────
ADMIN_PASSWORD=your_secure_admin_password

# ─────────────────────────────────────────────────────────────────
# Public vars below go in index.html / admin.html as JS constants
# SUPABASE_ANON_KEY=your_anon_key (client-side, read-only access)
